{
  "name": "aqa-bahave-taf",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate:endpoints": "cross-env TS_NODE_COMPILER_OPTIONS={\"module\":\"CommonJS\"} ts-node --skip-project scripts/generate-endpoints.ts",
    "validate:endpoints": "npx ts-node scripts/validate-endpoints.ts",
    "validate:endpoints:verbose": "npx ts-node scripts/validate-endpoints.ts --verbose",
    "mcp:contract": "npx ts-node scripts/contract-mcp-server.ts",
    "test:generate": "node -e \"require('fs').rmSync('.features-gen', { recursive: true, force: true })\" && npx bddgen",
    "test:run": "npx playwright test",
    "test:headed": "cross-env HEADLESS=false npx playwright test",
    "test:debug": "cross-env HEADLESS=false SLOW_MO=500 npx playwright test --debug",
    "test:ui": "npx playwright test --ui",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:smoke:log": "npx playwright test --grep @smoke --reporter=list 2>&1 | tee reports/smoke.log",
    "test:regression": "npx playwright test --grep @regression",
    "test:users": "npx playwright test --grep users",
    "test:cart": "npx playwright test --grep @cart",
    "test:catalog": "npx playwright test --grep @catalog",
    "test:checkout": "npx playwright test --grep @checkout",
    "report:html": "npx playwright show-report",
    "report:open": "npx playwright show-report",
    "clean": "rm -rf reports/ test-results/ playwright-report/",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "docker:test": "docker-compose run --rm playwright-tests npm run test",
    "docker:down": "docker-compose down",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,md}\"",
    "format:check": "prettier --check \"**/*.{ts,md}\"",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint",
    "test:product-detail": "npx playwright test --grep @product-detail",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@faker-js/faker": "^10.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/mcp": "^0.0.75",
    "@playwright/test": "^1.56.1",
    "@types/node": "22.15.17",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "playwright-bdd": "^8.4.2",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  }
}
